{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.5",
        "azure-oss/storage-blob-laravel": "^1.5",
        "cheesegrits/filament-google-maps": "^5.0",
        "dedoc/scramble": "^0.13.22",
        "fakerphp/faker": "^1.24",
        "filament/filament": "^5.2",
        "filament/spatie-laravel-media-library-plugin": "^5.6",
        "giggsey/libphonenumber-for-php": "^9.0",
        "google/apiclient": "^2.18",
        "joelbutcher/socialstream": "6.3",
        "kreait/firebase-php": "^7.24",
        "laravel-notification-channels/fcm": "^6.0",
        "laravel/framework": "^12.58",
        "laravel/jetstream": "^5.3",
        "laravel/pulse": "^1.6",
        "laravel/reverb": "^1.10",
        "laravel/sanctum": "^4.3",
        "laravel/socialite": "^5.27",
        "laravel/telescope": "^5.20",
        "league/flysystem-aws-s3-v3": "^3.31",
        "livewire/livewire": "^4.2",
        "maatwebsite/excel": "^3.1",
        "phpoffice/phpspreadsheet": "^1.29",
        "socialiteproviders/google": "^4.1",
        "spatie/laravel-activitylog": "^5.0",
        "spatie/laravel-backup": "^10.0",
        "spatie/laravel-medialibrary": "^11.22",
        "spatie/laravel-pdf": "^2.8",
        "spatie/laravel-permission": "^7.4",
        "spatie/laravel-query-builder": "^7.2",
        "spatie/laravel-sluggable": "^4.0",
        "spatie/temporary-directory": "^2.3",
        "tapp/filament-timezone-field": "^3.0",
        "ysfkaya/filament-phone-input": "^4.1"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^4.2",
        "barryvdh/laravel-ide-helper": "^3.6",
        "laradumps/laradumps": "^5.2",
        "larastan/larastan": "^3.9",
        "laravel/boost": "^2.4",
        "laravel/pint": "^1.29",
        "laravel/tinker": "^3.0",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.9",
        "pestphp/pest": "^4.6",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/Helpers/AutoloadHelper.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan ide-helper:generate",
            "@php artisan ide-helper:meta"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "audit": {
            "abandoned": "ignore",
            "ignore": {
                "CVE-2026-40902": "Wait for patch and update from maatwebsite/excel",
                "CVE-2026-40863": "Wait for patch and update from maatwebsite/excel",
                "CVE-2026-34084": "Wait for patch and update from maatwebsite/excel",
                "CVE-2026-40296": "Wait for patch and update from maatwebsite/excel",
                "CVE-2026-35453": "Wait for patch and update from maatwebsite/excel"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
